@{
    ViewData["Title"] = "Comprar Tiquetes";
    var eventoId = ViewBag.EventoId;
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <h2 class="mb-3">Comprar Tiquetes</h2>

        <div id="evento-info">
            <div class="text-center my-4">
                <div class="spinner-border spinner-border-sm"></div>
                Cargando información del evento
            </div>
        </div>

        <div id="alert-container"></div>

        <div id="compra-container" data-evento-id="@eventoId" class="card p-4 shadow-sm">
            <form id="compra-form">
                <div class="mb-3">
                    <label for="Cantidad" class="form-label">Cantidad de tiquetes</label>
                    <input type="number" id="Cantidad" class="form-control"
                           min="1" value="1" required />
                </div>
                <div class="mb-3">
                    <strong>Total a pagar:</strong>
                    <span id="total-calculado" class="fs-5 text-success ms-2">₡0.00</span>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" id="btn-submit" class="btn btn-success">
                        Confirmar Compra
                    </button>
                    <a href="/eventos" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/compra.js"></script>
}