@{
    ViewData["Title"] = "Crear Evento";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <h2 class="mb-3">Crear Nuevo Evento</h2>

        <div id="alert-container"></div>

        <form id="crear-evento-form" class="card p-4 shadow-sm">
            <div class="mb-3">
                <label for="Nombre" class="form-label">Nombre del evento</label>
                <input type="text" id="Nombre" class="form-control" required />
            </div>
            <div class="mb-3">
                <label for="Fecha" class="form-label">Fecha y hora</label>
                <input type="datetime-local" id="Fecha" class="form-control" required />
            </div>
            <div class="mb-3">
                <label for="Lugar" class="form-label">Lugar</label>
                <input type="text" id="Lugar" class="form-control" required />
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="Precio" class="form-label">Precio (₡)</label>
                    <input type="number" id="Precio" class="form-control"
                           min="0.01" step="0.01" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label for="CantidadDisponible" class="form-label">Tiquetes disponibles</label>
                    <input type="number" id="CantidadDisponible" class="form-control"
                           min="1" required />
                </div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" id="btn-submit" class="btn btn-primary">
                    Guardar Evento
                </button>
                <a href="/eventos" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/crear-evento.js"></script>
}