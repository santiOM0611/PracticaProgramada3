@{
    ViewData["Title"] = "Eventos Disponibles";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Eventos Disponibles</h2>
    @if (User.IsInRole(TiquetesApp.Constants.Roles.Admin))
    {
        <a href="/eventos/crear" class="btn btn-success">Crear Evento</a>
    }
</div>

<div id="eventos-loading" class="text-center my-4">
    <div class="spinner-border" role="status"></div>
    <p class="mt-2">Cargando eventos</p>
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Nombre</th>
            <th>Fecha</th>
            <th>Lugar</th>
            <th>Precio</th>
            <th>Disponibilidad</th>
            <th></th>
        </tr>
    </thead>
    <tbody id="eventos-tbody"></tbody>
</table>

@section Scripts {
    <script src="~/js/eventos-index.js"></script>
}