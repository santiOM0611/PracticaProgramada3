@model TiquetesApp.Models.ErrorViewModel
@{
    ViewData["Title"] = Model.StatusCode.HasValue ? $"Error {Model.StatusCode}" : "Error";
}

<div class="text-center mt-5">
    @if (Model.StatusCode.HasValue)
    {
        <h1 class="display-1 text-danger fw-bold">@Model.StatusCode</h1>
    }
    else
    {
        <h1 class="display-1 text-danger fw-bold">Error</h1>
    }

    <h2 class="text-muted">@Model.Message</h2>

    <p class="mt-4">
        <a href="/eventos" class="btn btn-primary">Volver al inicio</a>
    </p>
</div>

@if (Model.ShowRequestId)
{
    <div class="text-center mt-3">
        <small class="text-muted">Request ID: <code>@Model.RequestId</code></small>
    </div>
}